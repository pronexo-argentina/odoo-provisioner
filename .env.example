# --- Odoo ---
# URL local del Odoo que va a crear las bases (mismo server)
ODOO_URL=http://localhost:1969
# NOTA: la Master Password de Odoo NO se guarda acá; se ingresa en el formulario
# en cada alta (igual que en el gestor de bases de Odoo).
# Puertos de Odoo para el reverse proxy de nginx
ODOO_HTTP_PORT=1969
# Puerto gevent/websocket (odoo.conf: gevent_port). Ajustalo si no usás el default.
ODOO_LONGPOLLING_PORT=8072

# --- Backend de gestión de bases ---
# "odoo"     -> XML-RPC (requiere list_db = True en odoo.conf)
# "postgres" -> listar/crear/borrar sin el gestor de Odoo (funciona con list_db = False)
DB_BACKEND=odoo
# Lo de abajo SOLO aplica con DB_BACKEND=postgres:
ODOO_CONF=/etc/odoo/odoo.conf
# Python que tiene el paquete odoo importable (el del venv de Odoo). Ej:
#   /opt/odoo/venv/bin/python3   (o "python3" si Odoo está instalado a nivel sistema)
ODOO_PYTHON=python3
ODOO_SYSTEM_USER=odoo
ODOO_DB_USER=odoo
POSTGRES_SYSTEM_USER=postgres
PSQL_BIN=/usr/bin/psql
DROPDB_BIN=/usr/bin/dropdb

# --- Dominios ---
# Dominio base bajo el que se crean los subdominios (informativo)
BASE_DOMAIN=midominio.com
# Email para el registro de Let's Encrypt
LETSENCRYPT_EMAIL=admin@midominio.com

# --- nginx ---
NGINX_SITES_AVAILABLE=/etc/nginx/sites-available
NGINX_SITES_ENABLED=/etc/nginx/sites-enabled
NGINX_BIN=/usr/sbin/nginx
CERTBOT_BIN=/usr/bin/certbot

# --- App ---
# Poné esto en false para probar en tu Mac sin tocar nginx/certbot ni Odoo real
APPLY_SYSTEM_CHANGES=true
# Token simple para proteger la API (mandalo en el header X-Auth-Token)
API_TOKEN=
